
# ======================================================
# 🧠 Golem Brain (Web Gemini 大腦設定)
# ======================================================
# Google Gemini API Keys (必填)
# 說明：用於 DOM Doctor 自癒功能與與某些對話分析。
# 取得：https://aistudio.google.com/app/apikey
# 技巧：支援多組 Key 輪替 (KeyChain)，請用半形逗號 "," 分隔。
# ⚠️ 首次啟動後請前往 http://localhost:3000/dashboard 進行設定。

GEMINI_API_KEYS=

# Gemini Web URLs (高可用備用網址)
# 說明：支援多組網址輪替，若第一組失效則自動使用後續網址。以半形逗號 "," 分隔。
# 預設：https://gemini.google.com/app,https://gemini.google.com/app?hl=zh-TW
GEMINI_URLS=https://gemini.google.com/app,https://gemini.google.com/app?hl=zh-TW

# ======================================================
# ⚙️ System Config (系統進階設定)
# ======================================================
# 🎭 Playwright Profile (多 Profile 支援)
# 說明：設定此變數可讓您切換不同的瀏覽器環境 (Session/Cookies/Skills)。
# 預設：若不填則為空，系統將回退使用 ./golem_memory。
# 建議：填入簡單的英文代號，例如: default, work, personal
PLAYWRIGHT_PROFILE=

# 瀏覽器資料暫存路徑 (進階)
# 說明：存放瀏覽器 Session，若設定此項則會覆蓋 PLAYWRIGHT_PROFILE 的預設路徑。
# 預設：空值 (由 PLAYWRIGHT_PROFILE 決定)
USER_DATA_DIR=

# 測試模式 (通常設為 false)
# true: 只測試程式碼是否能執行，不啟動瀏覽器。
# false: 正常啟動。

GOLEM_TEST_MODE=false

# 👻 無頭模式 (可選，預設不填或 false)
# 說明：設定為 true 會讓 Playwright 瀏覽器完全在背景隱形執行 (不跳出視窗)。
# ⚠️ 注意：首次使用 Gemini 必須登入 Google 帳號與解開 CAPTCHA，因此第一次啟動請把此處留空。
# 等確定已經有 `golem_memory` 的登入紀錄後，再設定為 true 來達到最舒適的體驗。

PLAYWRIGHT_HEADLESS=

# 部署模式 (固定為 SINGLE)
# SINGLE: 單機模式，使用單一組 Telegram/Discord 設定。

GOLEM_MODE=SINGLE

# Web Dashboard 埠號 (預設 3000)
DASHBOARD_PORT=3000

# 控制台啟用開關 (true | false)
ENABLE_WEB_DASHBOARD=true

# 系統初次初始化標記
SYSTEM_CONFIGURED=false

# Dashboard 開發模式 (true | false)
# 說明：設為 true 可跳過 npm run build，使用 Next.js 開發伺服器。
DASHBOARD_DEV_MODE=true

# ======================================================
# 🧠 Memory Engine (記憶引擎設定)
# ======================================================
# 選擇模式：
# browser - (預設) 使用內建 memory.html，無須安裝額外軟體。
# qmd     - (進階) 使用 qmd 混合搜尋，需安裝 Bun 與 qmd。
# (進階選用) 指定 qmd 執行檔路徑，若已加入系統 PATH 則留空即可
# GOLEM_QMD_PATH=/path/to/your/qmd

GOLEM_MEMORY_MODE=browser

# ======================================================
# ☁️ OTA Update Config (空中升級設定)
# ======================================================
# 指定 /update 指令抓取原始碼的 GitHub 儲存庫
# 預設若留空則使用：https://raw.githubusercontent.com/Arvincreator/project-golem/main/

GITHUB_REPO=

# ======================================================
# 🦞 Moltbook Social Network (AI 社交網絡)
# ======================================================
# Moltbook API Key (核心憑證)
# 取得方式：啟動 Golem 後，對他說「去註冊 Moltbook」。

MOLTBOOK_API_KEY=

MOLTBOOK_AGENT_NAME=

PLAYWRIGHT_REMOTE_DEBUGGING_PORT=9222

ENABLE_LOG_NOTIFICATIONS=false

# ======================================================
# 🌐 Remote Access (遠端連線設定)
# ======================================================
# 是否允許從區域網路或外部 IP 連線 Dashboard。
# true  - 開放所有來源（適合遠端或 LAN 連線）
# false - 僅限本機 localhost 連線（預設，較安全）
# ⚠️ 若設為 true，請確保已有防火牆或 VPN 保護。

ALLOW_REMOTE_ACCESS=false
